{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": false,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
     "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["jest", "node"],
    "isolatedModules": true

  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
